{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "^/design-system(\\.html)?$", "status": 404 },
    { "src": "^/it-services-landing.*$", "status": 404 },
    { "src": "^/$", "dest": "/index.html" },
    { "src": "^/managed-it$", "dest": "/managed-it.html" },
    { "src": "^/cybersecurity$", "dest": "/cybersecurity.html" },
    { "src": "^/compliance$", "dest": "/compliance.html" },
    { "src": "^/cloud-communications$", "dest": "/cloud-communications.html" },
    { "src": "^/infrastructure$", "dest": "/infrastructure.html" },
    { "src": "^/services$", "dest": "/services.html" },
    { "src": "^/about$", "dest": "/about.html" },
    { "src": "^/contact$", "dest": "/contact.html" },
    { "src": "^/industries$", "dest": "/industries.html" },
    { "src": "^/privacy$", "dest": "/privacy.html" },
    { "src": "^/terms$", "dest": "/terms.html" }
  ]
}
